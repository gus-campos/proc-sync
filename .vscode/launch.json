{
    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET Core Launch (console)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/ProcSync.ConsoleApp/bin/Debug/net8.0/ProcSync.ConsoleApp.dll",
            "args": ["producer-consumer"],
            "cwd": "${workspaceFolder}/ProcSync.ConsoleApp",
            "console": "internalConsole",
            "stopAtEntry": false
        }
    ]
}
