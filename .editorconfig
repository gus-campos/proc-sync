root = true

########################################

# GLOBAL

########################################
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4

########################################

# C#

########################################
[*.cs]

########################################

# 🔹 FORMATAÇÃO (ALLMAN STYLE)

########################################
csharp_new_line_before_open_brace = all
csharp_indent_case_contents = true
csharp_indent_switch_labels = true
csharp_indent_labels = flush_left

########################################

# 🔹 USING ORGANIZATION

########################################
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = true

########################################

# 🔹 VAR USAGE

########################################
csharp_style_var_for_built_in_types = false:warning
csharp_style_var_when_type_is_apparent = true:warning
csharp_style_var_elsewhere = false:warning

########################################

# 🔹 EXPRESSÕES

########################################
csharp_prefer_braces = true:error
csharp_style_expression_bodied_methods = false:warning
csharp_style_expression_bodied_constructors = false:warning
csharp_style_expression_bodied_properties = true:warning

########################################

# 🔹 NULLABLE / SEGURANÇA

########################################
dotnet_style_null_propagation = true:warning
dotnet_style_coalesce_expression = true:warning

########################################

# 🔹 NOMENCLATURA

########################################

# ===== RULES =====

# Classes

dotnet_naming_rule.classes_pascal_case.severity = error
dotnet_naming_rule.classes_pascal_case.symbols = classes
dotnet_naming_rule.classes_pascal_case.style = pascal

# Métodos

dotnet_naming_rule.methods_pascal_case.severity = error
dotnet_naming_rule.methods_pascal_case.symbols = methods
dotnet_naming_rule.methods_pascal_case.style = pascal

# Propriedades

dotnet_naming_rule.properties_pascal_case.severity = error
dotnet_naming_rule.properties_pascal_case.symbols = properties
dotnet_naming_rule.properties_pascal_case.style = pascal

# Interfaces (IAlgumaCoisa)

dotnet_naming_rule.interfaces_pascal_case.severity = error
dotnet_naming_rule.interfaces_pascal_case.symbols = interfaces
dotnet_naming_rule.interfaces_pascal_case.style = pascal_with_i

# Campos privados (_camelCase)

dotnet_naming_rule.private_fields_camel_case.severity = warning
dotnet_naming_rule.private_fields_camel_case.symbols = private_fields
dotnet_naming_rule.private_fields_camel_case.style = camel_with_underscore

# Variáveis locais (camelCase)

dotnet_naming_rule.locals_camel_case.severity = warning
dotnet_naming_rule.locals_camel_case.symbols = locals
dotnet_naming_rule.locals_camel_case.style = camel

########################################

# 🔹 SYMBOLS

########################################

dotnet_naming_symbols.classes.applicable_kinds = class
dotnet_naming_symbols.classes.applicable_accessibilities = *

dotnet_naming_symbols.methods.applicable_kinds = method
dotnet_naming_symbols.methods.applicable_accessibilities = *

dotnet_naming_symbols.properties.applicable_kinds = property
dotnet_naming_symbols.properties.applicable_accessibilities = *

dotnet_naming_symbols.interfaces.applicable_kinds = interface
dotnet_naming_symbols.interfaces.applicable_accessibilities = *

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private

dotnet_naming_symbols.locals.applicable_kinds = local
dotnet_naming_symbols.locals.applicable_accessibilities = *

########################################

# 🔹 STYLES

########################################

# PascalCase

dotnet_naming_style.pascal.capitalization = pascal_case

# PascalCase com I

dotnet_naming_style.pascal_with_i.capitalization = pascal_case
dotnet_naming_style.pascal_with_i.required_prefix = I

# camelCase

dotnet_naming_style.camel.capitalization = camel_case

# _camelCase

dotnet_naming_style.camel_with_underscore.capitalization = camel_case
dotnet_naming_style.camel_with_underscore.required_prefix = _

########################################

# 🔹 QUALIDADE DE CÓDIGO

########################################

# Usar readonly quando possível

dotnet_style_readonly_field = true:warning

# Evitar this desnecessário

dotnet_style_qualification_for_field = false:warning
dotnet_style_qualification_for_property = false:warning

# Preferir interpolação

dotnet_style_prefer_interpolated_string = true:warning

# Evitar código morto

dotnet_diagnostic.CS0168.severity = warning
dotnet_diagnostic.CS0219.severity = warning

########################################

# 🔹 FORMATAÇÃO FINAL

########################################
dotnet_style_require_accessibility_modifiers = always:error
